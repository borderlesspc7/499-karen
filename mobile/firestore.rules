rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /campaigns/{campaignId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /opportunities/{opportunityId} {
      allow read, write: if isSignedIn();
    }

    match /kanban_columns/{columnId} {
      allow read, write: if isSignedIn();
    }

    match /automations/{automationId} {
      allow read, write: if isSignedIn();
    }

    // Tokens OAuth — somente Cloud Functions (Admin SDK)
    match /integration_secrets/{userId}/{document=**} {
      allow read, write: if false;
    }

    // Status público das conexões (sem tokens)
    match /channel_connections/{userId}/channels/{channelId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['unreadCount', 'status', 'preview', 'updatedAt']);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid;

        allow write: if false;
      }
    }
  }
}
