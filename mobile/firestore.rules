rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnResource() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwner() {
      return request.resource.data.userId == resource.data.userId;
    }

    // Assinatura: cliente só grava mode == 'mock' (demo). Stripe real = Admin SDK.
    function subscriptionWriteAllowed() {
      return !('subscription' in request.resource.data)
        || request.resource.data.subscription == null
        || (
          request.resource.data.subscription.keys().hasAll(['mode', 'status', 'planId'])
          && request.resource.data.subscription.mode == 'mock'
          && request.resource.data.subscription.status == 'active'
        )
        || (
          resource.data.keys().hasAny(['subscription'])
          && request.resource.data.subscription == resource.data.subscription
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && (
          !('subscription' in request.resource.data)
          || request.resource.data.subscription == null
          || (
            request.resource.data.subscription.keys().hasAll(['mode', 'status', 'planId'])
            && request.resource.data.subscription.mode == 'mock'
            && request.resource.data.subscription.status == 'active'
          )
        );
      allow update: if isOwner(userId) && subscriptionWriteAllowed();
      allow delete: if isOwner(userId);

      match /campaigns/{campaignId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /campaigns/{campaignId} {
      allow read: if ownsResource();
      allow create: if createsOwnResource();
      allow update, delete: if ownsResource() && keepsOwner();
    }

    match /clients/{clientId} {
      allow read: if ownsResource();
      allow create: if createsOwnResource();
      allow update, delete: if ownsResource() && keepsOwner();
    }

    match /opportunities/{opportunityId} {
      allow read: if ownsResource();
      allow create: if createsOwnResource();
      allow update, delete: if ownsResource() && keepsOwner();
    }

    match /kanban_columns/{columnId} {
      allow read: if ownsResource();
      allow create: if createsOwnResource();
      allow update, delete: if ownsResource() && keepsOwner();
    }

    match /automations/{automationId} {
      allow read: if ownsResource();
      allow create: if createsOwnResource();
      allow update, delete: if ownsResource() && keepsOwner();
    }

    // Tokens OAuth — somente Cloud Functions (Admin SDK)
    match /integration_secrets/{userId}/{document=**} {
      allow read, write: if false;
    }

    // Status público das conexões (sem tokens)
    match /channel_connections/{userId}/channels/{channelId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Stripe — somente Admin SDK
    match /stripe_webhook_events/{eventId} {
      allow read, write: if false;
    }

    match /stripe_checkout_sessions/{sessionId} {
      allow read, write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if ownsResource();

      allow create: if createsOwnResource();

      allow update: if ownsResource()
        && keepsOwner()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['unreadCount', 'status', 'preview', 'updatedAt']);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId
            == request.auth.uid;

        allow write: if false;
      }
    }
  }
}
