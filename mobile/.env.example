# Firebase Client SDK (Expo / React Native)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Emulador local de Cloud Functions (dev)
# EXPO_PUBLIC_FUNCTIONS_EMULATOR=1

# --- Cloud Functions (configurar no Firebase, NÃO no app) ---
# firebase functions:secrets:set META_APP_SECRET
# firebase functions:secrets:set META_WEBHOOK_VERIFY_TOKEN
# firebase functions:secrets:set LINKEDIN_CLIENT_SECRET
# firebase functions:config:set meta.app_id="..." linkedin.client_id="..."

# Meta (Facebook Developers): WhatsApp + Instagram + Messenger
# 1. Criar app em developers.facebook.com
# 2. Adicionar produtos: WhatsApp, Instagram, Messenger
# 3. Configurar OAuth redirect: https://us-central1-SEU_PROJECT.cloudfunctions.net/oauthCallback
# 4. Configurar webhook: https://us-central1-SEU_PROJECT.cloudfunctions.net/metaWebhook
#    - Verify token: mesmo valor de META_WEBHOOK_VERIFY_TOKEN
#    - Campos: messages, messaging_postbacks

# LinkedIn Developer Portal
# Redirect URL: https://us-central1-SEU_PROJECT.cloudfunctions.net/oauthCallback
